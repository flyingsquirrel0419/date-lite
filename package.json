{
  "name": "date-light",
  "version": "0.1.3",
  "description": "Zero-dependency, ~2.19KB minzipped, fully typed date utility library — 39 functions covering the 20 most-used date-fns operations",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "docs:build": "vite build --outDir dist-docs && node ./scripts/build-docs.cjs",
    "docs:preview": "vite preview --outDir dist-docs --host 127.0.0.1",
    "build": "tsup",
    "test": "vitest run",
    "test:package": "npm run build && node ./scripts/test-package.cjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run test:package"
  },
  "keywords": [
    "date",
    "date-fns",
    "date-light",
    "format",
    "parse",
    "utility",
    "tiny",
    "lightweight",
    "minimal"
  ],
  "author": "flyingsquirrel0419",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingsquirrel0419/date-light"
  },
  "homepage": "https://github.com/flyingsquirrel0419/date-light#readme",
  "bugs": {
    "url": "https://github.com/flyingsquirrel0419/date-light/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
